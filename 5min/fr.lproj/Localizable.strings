/* Science */
"science_title" = "La Science";
"science_subtitle" = "Pourquoi 5 minutes ?";
"why_5min_title" = "Pourquoi seulement 5 minutes ?";
"why_5min_body" = "La recherche montre que le plus grand obstacle à une tâche est de la commencer. Une fois que l'on commence, on est naturellement porté à continuer. 5 minutes suffisent à briser cette résistance mentale.";

"science_zeigarnik_source" = "Recherche Psychologique, 1927";
"science_zeigarnik_quote" = "Les tâches inachevées restent actives dans notre mémoire longtemps après que les tâches terminées se soient effacées.";
"science_zeigarnik_explanation" = "Bluma Zeigarnik a découvert que commencer une tâche — même brièvement — crée une boucle mentale ouverte qui maintient l'engagement et motive à revenir. 5 minutes suffisent à activer cet effet.";

"science_clear_quote" = "Tu ne t'élèves pas au niveau de tes objectifs. Tu tombes au niveau de tes systèmes. 5 minutes, c'est ton système.";
"science_clear_explanation" = "James Clear démontre que la motivation suit l'action, pas l'inverse. En s'engageant sur seulement 5 minutes, on supprime la friction qui bloque le démarrage — et une fois lancé, l'élan prend le relais.";

"science_huberman_quote" = "La dopamine est libérée en anticipation d'une récompense, pas seulement à sa réception. Commencer une tâche déclenche ce mécanisme de récompense interne.";
"science_huberman_explanation" = "Le Dr. Huberman explique que le simple fait de commencer une tâche déclenche la libération de dopamine, créant une boucle de motivation naturelle. 5 minutes suffisent à activer cette réponse neurochimique.";

"science_fogg_quote" = "Rends-le minuscule. Quand un comportement est suffisamment petit, il devient facile à faire — et facile à répéter.";
"science_fogg_explanation" = "La recherche de BJ Fogg montre que réduire la friction en rendant les habitudes petites est la clé pour les ancrer. 5 minutes supprime l'objection 'c'est trop difficile' et permet de construire une vraie régularité.";

"science_steel_source" = "L'Équation de la Procrastination, 2011";
"science_steel_quote" = "La procrastination augmente avec la distance temporelle. Plus l'échéance est lointaine, plus on tarde. Commencer maintenant réduit cette distance à zéro.";
"science_steel_explanation" = "L'équation de la procrastination du Dr. Steel montre que l'immédiateté est l'antidote au report. S'engager sur 5 minutes maintenant te force dans le moment présent et brise le cycle du report.";

