/* Science */
"science_title" = "The Science";
"science_subtitle" = "Why 5 minutes?";
"why_5min_title" = "Why just 5 minutes?";
"why_5min_body" = "Research shows that the biggest obstacle to any task is starting it. Once you begin, you're naturally drawn to continue. 5 minutes is enough to break that mental resistance.";

"science_zeigarnik_source" = "Psychological Research, 1927";
"science_zeigarnik_quote" = "Unfinished tasks remain active in our memory long after completed tasks have faded.";
"science_zeigarnik_explanation" = "Bluma Zeigarnik discovered that starting a task — even briefly — creates an open mental loop that keeps you engaged and motivated to return. 5 minutes is all it takes to activate this effect.";

"science_clear_quote" = "You don't rise to the level of your goals. You fall to the level of your systems. 5 minutes is your system.";
"science_clear_explanation" = "James Clear demonstrates that motivation follows action, not the other way around. By committing to just 5 minutes, you eliminate the friction that blocks you from starting — and once started, momentum carries you forward.";

"science_huberman_quote" = "Dopamine is released in anticipation of a reward, not just upon receiving it. Starting a task triggers this internal reward mechanism.";
"science_huberman_explanation" = "Dr. Huberman explains that simply beginning a task triggers dopamine release, creating a natural motivation loop. 5 minutes is enough to activate this neurochemical response and build genuine drive.";

"science_fogg_quote" = "Make it tiny. When you make a behavior tiny enough, it becomes easy to do — and easy to repeat.";
"science_fogg_explanation" = "BJ Fogg's research shows that reducing friction by making habits small is the key to making them stick. 5 minutes removes the 'it's too hard' objection and lets you build real consistency.";

"science_steel_source" = "The Procrastination Equation, 2011";
"science_steel_quote" = "Procrastination increases with temporal distance. The further away the deadline, the more we delay. Starting now collapses that distance to zero.";
"science_steel_explanation" = "Dr. Steel's procrastination equation shows that immediacy is the antidote to delay. Committing to 5 minutes right now forces you into the present moment and breaks the cycle of postponement.";

